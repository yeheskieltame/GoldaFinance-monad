# -----------------------------------------------------------------------------
# GoldaVault deployment env. Copy to .env and fill in; .env is gitignored.
# -----------------------------------------------------------------------------

# Deployer private key (0x-prefixed). Must hold MON for gas on Monad mainnet.
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# Operator address — allowed to call execute(), approveToken(), reportNav().
# Usually your backend/keeper EOA. Defaults to deployer if unset.
OPERATOR=0xYourOperatorAddress

# Etherscan API v2 key (single key works for every chain supported by v2,
# including Monad mainnet 143 and Monad testnet 10143).
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_V2_API_KEY

# -----------------------------------------------------------------------------
# DEPLOY + VERIFY (two-step — Foundry 1.5.x refuses inline --verify for
# chain 143 because Monad mainnet isn't in its named-chain registry yet;
# forge verify-contract accepts the numeric chain id just fine).
# -----------------------------------------------------------------------------
#
# 1) Deploy (mainnet):
#
#    source .env
#    forge script script/DeployGoldaVault.s.sol:DeployGoldaVault \
#      --rpc-url monad-mainnet \
#      --broadcast \
#      -vvvv
#
# 2) Grab the deployed address (last successful broadcast) and verify:
#
#    VAULT=$(jq -r '.transactions[] | select(.contractName=="GoldaVault") | .contractAddress' \
#      broadcast/DeployGoldaVault.s.sol/143/run-latest.json)
#
#    forge verify-contract "$VAULT" src/GoldaVault.sol:GoldaVault \
#      --chain 143 \
#      --verifier etherscan \
#      --verifier-url 'https://api.etherscan.io/v2/api?chainid=143' \
#      --etherscan-api-key "$ETHERSCAN_API_KEY" \
#      --constructor-args $(cast abi-encode 'constructor(address,address)' \
#        0x754704Bc059F8C67012fEd69BC8A327a5aafb603 "$OPERATOR") \
#      --watch
#
# Monad testnet: swap --rpc-url monad-testnet, --chain 10143,
# chainid=10143 in the URL, and broadcast path 10143/run-latest.json.
# -----------------------------------------------------------------------------
