# =============================================
# Golda Finance — Environment variables
# =============================================

# Network — defaults to Monad Testnet
NEXT_PUBLIC_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_EXPLORER_URL=https://testnet.monadscan.com

# GoldaVault contract (same address on Monad mainnet + testnet)
NEXT_PUBLIC_GOLDA_VAULT_ADDRESS=0xbf8f03002e91daacc8e3597d650a4f1b2d21a39e
NEXT_PUBLIC_USDC_ADDRESS=0x754704Bc059F8C67012fEd69BC8A327a5aafb603

# Wallet auth
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# AI agent
NEXT_PUBLIC_GEMINI_API_KEY=
GEMINI_API_KEY=

# x402 payments (server-side wallet that fulfills smart deposits)
AI_AGENT_PRIVATE_KEY=
NEXT_PUBLIC_X402_PAYEE=

# Cron auth secret
CRON_SECRET=

# Branding
NEXT_PUBLIC_APP_NAME=GoldaFinance
NEXT_PUBLIC_APP_DESCRIPTION=Inflation-resistant savings on Monad
